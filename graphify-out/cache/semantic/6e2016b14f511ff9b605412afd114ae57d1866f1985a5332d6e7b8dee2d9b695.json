{"nodes": [{"id": "references_transcribe_graphify_reference", "label": "graphify reference: transcribe video and audio", "file_type": "document", "source_file": ".codex/skills/graphify/references/transcribe.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "references_transcribe_video_audio_transcription", "label": "Transcribe video and audio", "file_type": "rationale", "source_file": ".codex/skills/graphify/references/transcribe.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Video and audio files cannot be read directly by text-based semantic extraction, so they must be transcribed to text before downstream processing."}, {"id": "references_transcribe_detect_video_files", "label": "Detect video files", "file_type": "rationale", "source_file": ".codex/skills/graphify/references/transcribe.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Transcription is only loaded when the detect step reports one or more video files, avoiding unnecessary work on text-only corpora."}, {"id": "references_transcribe_whisper_prompt", "label": "Whisper prompt", "file_type": "rationale", "source_file": ".codex/skills/graphify/references/transcribe.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "An initial prompt primes Whisper with domain vocabulary from the corpus god nodes, improving transcription accuracy and formatting."}, {"id": "references_transcribe_domain_hint", "label": "Domain hint sentence", "file_type": "rationale", "source_file": ".codex/skills/graphify/references/transcribe.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Constructed from the top god-node labels, this sentence gives Whisper context about the expected domain and terminology."}, {"id": "references_transcribe_generic_fallback_prompt", "label": "Generic fallback prompt", "file_type": "rationale", "source_file": ".codex/skills/graphify/references/transcribe.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "When the corpus contains only video files, no god-node labels exist to build a domain hint, so a generic punctuation prompt is used instead."}, {"id": "references_transcribe_whisper_model", "label": "Whisper model", "file_type": "rationale", "source_file": ".codex/skills/graphify/references/transcribe.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The ASR model used by transcribe_all is configurable via --whisper-model, defaulting to base for a balance of speed and accuracy."}, {"id": "references_transcribe_transcribe_all", "label": "transcribe_all", "file_type": "code", "source_file": ".codex/skills/graphify/references/transcribe.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "references_transcribe_graphify_detect_json", "label": "graphify detect output (.graphify_detect.json)", "file_type": "document", "source_file": ".codex/skills/graphify/references/transcribe.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "references_transcribe_graphify_transcripts_json", "label": "graphify transcripts output (.graphify_transcripts.json)", "file_type": "document", "source_file": ".codex/skills/graphify/references/transcribe.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "references_transcribe_graphify_reference", "target": "references_transcribe_video_audio_transcription", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".