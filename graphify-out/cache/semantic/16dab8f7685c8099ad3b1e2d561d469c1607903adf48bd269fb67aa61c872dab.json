ept", "source_file": ".codex/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "references_query_vocab_token_selection", "label": "Vocab token selection", "file_type": "rationale", "rationale": "Up to 12 tokens are selected from the extracted vocabulary to match the query intent. Cross-language terms are translated to the closest English tokens present in the vocabulary; morphology is mapped only when the base token exists.", "source_file": ".codex/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "references_query_inline_networkx_traversal", "label": "Inline NetworkX traversal", "file_type": "concept", "source_file": ".codex/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "references_query_graphify_query_cli", "label": "graphify query CLI", "file_type": "concept", "source_file": ".codex/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "references_query_save_result", "label": "save-result command", "file_type": "concept", "source_file": ".codex/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "references_query_token_budget", "label": "Token budget", "file_type": "rationale", "rationale": "Traversal output is ranked by term relevance and truncated at a character budget derived from the token budget to control response length and cost.", "source_file": ".codex/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "references_query_graphify_query", "target": "references_q