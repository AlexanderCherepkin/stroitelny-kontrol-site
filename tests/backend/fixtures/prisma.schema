generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  company   String?
  budget    Float?
  createdAt DateTime @default(now())
}

enum Status {
  ACTIVE
  INACTIVE
}
