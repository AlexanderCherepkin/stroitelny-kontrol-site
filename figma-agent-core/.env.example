# ---------------------------------------------------------------------------
#  FIGMA AGENT — environment template
#  1. Copy this file to `.env` and fill in your real values.
#  2. NEVER commit `.env` — it is already listed in `.gitignore`.
#  3. If you shared the old token, revoke it in Figma and generate a new one.
# ---------------------------------------------------------------------------

# --- Figma API (required) ----------------------------------------------------
# Get your token at: https://www.figma.com/developers/api#access-tokens
FIGMA_TOKEN=figd_YOUR_FIGMA_TOKEN_HERE

# Figma file key is the long id in the URL:
# https://www.figma.com/design/FILE_KEY/...?node-id=NODE_ID
FIGMA_FILE_KEY=YOUR_FILE_KEY_HERE

# Optional: target a specific node (e.g. 0-1 or 123-456). Falls back to the
# node-id from FIGMA_URL or to the canvas root.
FIGMA_NODE_ID=0-1

# Legacy / convenience: full Figma URL. Used only if FIGMA_FILE_KEY is empty.
# FIGMA_URL=https://www.figma.com/design/YOUR_FILE_KEY/YOUR_FILE_NAME?node-id=0-1

# --- LLM Provider (choose ONE option and comment out the others) -------------

# Option A — Local Ollama (default, no paid key required)
LLM_API_KEY=ollama-dummy-key
LLM_API_URL=http://localhost:11434/v1/chat/completions
LLM_MODEL=qwen2.5-coder:7b

# Option B — Moonshot Kimi API
# LLM_API_KEY=sk-YOUR_KIMI_API_KEY
# LLM_API_URL=https://api.moonshot.cn/v1/chat/completions
# LLM_API_MODEL=kimi-k2.5-code:cloud

# Option C — Claude / Anthropic API
# LLM_API_KEY=sk-ant-api03-YOUR_ANTHROPIC_KEY
# LLM_API_URL=https://api.anthropic.com/v1/messages
# LLM_MODEL=claude-sonnet-4-6

# You can also use ANTHROPIC_API_KEY as a fallback if LLM_API_KEY is empty.
# ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ANTHROPIC_KEY

# --- MCP / runtime (optional) ------------------------------------------------
# Port used when the Figma MCP server is launched as a standalone service.
MCP_PORT=8080
